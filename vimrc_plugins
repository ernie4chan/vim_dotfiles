"{{{ --- 1. netrw (Network oriented, writing and browsing) -------------------

" Setting the width of the directory explorer.
let g:netrw_winsize = -31

" Do not display info on the top of window.
let g:netrw_banner = 0

" Creates a lots of garbage files. 3 for Tree mode.
let g:netrw_liststyle = 3

" Sort is affecting only: directories on the top, files below.
let g:netrw_sort_sequence = '[\/]$,*'

" Hit enter in the file browser to open the selected file,
" with :vsplit to the right of the browser.
let g:netrw_browse_split = 4
let g:netrw_altv = 1

