"{{{ --- 2. NERDTree (File system explorer) ----------------------------------

" Mappings.
nnoremap <silent><Leader>f :NERDTreeFind<CR>
nnoremap <silent><Leader>n :NERDTreeToggle<CR>

" Size of NERTree window.
let g:NERDTreeWinSize = 31

" Disable 'Bookmarks' and 'Press ?...' label.
let g:NERDTreeMinimalUI = 1

" Sort from '1, 2,.. 5..'.
let g:NERDTreeNaturalSort = 1

" Sort nodes case sensitively.
let g:NERDTreeCaseSensitiveSort = 1

" Delete no more valid buffer when deleting / renaming with context menu.
let g:NERDTreeAutoDeleteBuffer = 1

" Use global statusline with '-1'.
let g:NERDTreeStatusLine = -1

" Automatically close NERDTree when you open a file.
let g:NERDTreeQuitOnOpen = 1

if has('autocmd')
	" Close Vim if the only window left open is a NERDTree.
	augroup nerdtree_close_if_one_window
		autocmd!
		autocmd bufenter * 
			\ if (winnr("$") == 1 && exists("b:NERDTree") && b:NERDTree.isTabTree()) |
			\	q |
			\ endif
	augroup END
endif

