" {{{ --- 0. Mappings and Basics ---

" My favorites, sometimes SHIFT gets caught.
command W write
command Q quit

" Shortcut to clear highlights.
nnoremap <silent><C-l> :<C-u>nohlsearch<CR><C-l>

" Switching between buffers.
" (- and + images on Fn)
nnoremap <silent><F8> :bprev<CR>
nnoremap <silent><F9> :bnext<CR>

" Toggle auto-indenting on and off for code pasting.
" (Lock image on Fn)
set pastetoggle=<F3>

" Deploy rot13 encryption for people snooping over shoulder.
" (Wifi image on Fn)
noremap <silent><F5> <ESC>ggVGg?

" Display unprintable characters.
" (Cam image on Fn)
nnoremap <silent><F6> :set list!<CR>:setlocal list?<CR>

" Destroying trailing whitespaces.
" (Projector image on Fn)
nnoremap <silent><F7> :let _s=@/<Bar>:%s/\s\+$//e<Bar>:let @/=_s<Bar>:nohl<Bar>:unlet _s<CR>

if has('autocmd')
	augroup auto_save_lost_focus
		autocmd!
		autocmd TabLeave * silent! wall
		autocmd FocusLost * silent! wall
	augroup END

	augroup reopen_line_return
		autocmd!
		autocmd BufReadPost * if line("'\"") > 0 && line("'\"") <= line("$")
			\| execute "normal! g`\"" | endif
	augroup END
endif

